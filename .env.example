# ============================================================
# StokPilot API — Environment Variables
# Copy this file to apps/api/.env.local and fill in values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_long_secret_key
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_EXPIRATION=900          # access token TTL in seconds (15 min)
JWT_REFRESH_EXPIRATION=604800  # refresh token TTL in seconds (7 days)

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ── AWS / S3 (PDF & image storage) ───────────────────────────
S3_ENABLED=false
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=stokpilot-uploads

# ── WhatsApp Business API ─────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxx

# ── OCR ──────────────────────────────────────────────────────
OCR_ENABLED=false

# ── Sync (ERP/POS integration) ───────────────────────────────
SYNC_ENABLED=false

# ── OTP (SMS) ────────────────────────────────────────────────
OTP_ENABLED=false
# When false: OTP is always 123456, printed to console

# ── Supplier Portal ──────────────────────────────────────────
PORTAL_JWT_SECRET=change_me_portal_secret_min_32_chars__
# Portal session tokens expire after 30 minutes
