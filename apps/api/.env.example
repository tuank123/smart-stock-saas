# StokPilot API Environment Variables

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://stok_user:stok_password@localhost:5432/stok_dev

# ============================================
# JWT TOKENS
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long!!!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long!!!
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# ============================================
# WHATSAPP (Meta Cloud API)
# ============================================
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=placeholder
WHATSAPP_ACCESS_TOKEN=placeholder
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# Meta webhook doğrulama token'ı (GET /whatsapp/webhook hub.verify_token ile eşleşmeli)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=stokpilot-webhook-verify-2026

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================
# SENDGRID_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
