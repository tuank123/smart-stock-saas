// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  SUPER_ADMIN
  PATRON
  SUBE_MUDURU
  KASIYER
  DEPO
}

enum StaffTokenStatus {
  PENDING
  APPROVED
  USED
  CANCELLED
}

// ============================================
// CORE TABLES
// ============================================

/// Multi-tenant root entity
model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId    TenantPlan @default(STARTER) @map("plan_id")
  companyName String @map("company_name")
  taxNumber String @unique @map("tax_number")
  status    TenantStatus @default(ACTIVE)
  settings  Json? // flexible config storage
  
  // Relations
  users                    User[]
  branches                 Branch[]
  staffRegistrationTokens  StaffRegistrationToken[]
  branchIntegrations       BranchIntegration[]
  categories               Category[]
  products                 Product[]
  stockLevels              StockLevel[]
  stockMovements           StockMovement[]
  suppliers                Supplier[]
  purchaseOrders           PurchaseOrder[]
  stockTransfers           StockTransfer[]
  whatsappMessageLogs      WhatsappMessageLog[]
  ocrScans                 OcrScan[]
  syncQueues               SyncQueue[]
  syncLogs                 SyncLog[]
  branchSupplierPortals    BranchSupplierPortal[]
  supplierPortalUploads    SupplierPortalUpload[]
  scheduledReports         ScheduledReport[]
  priceChangeLogs          PriceChangeLog[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete

  @@map("tenants")
  @@index([status])
  @@index([deletedAt])
}

/// User accounts - multi-tenant
model User {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid @map("tenant_id")
  branchId        String?  @db.Uuid @map("branch_id")
  email           String   @map("email")
  fullName        String?  @map("full_name")
  passwordHash    String   @map("password_hash")
  role            UserRole?
  isActive        Boolean  @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  
  // Relations
  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  stockMovements          StockMovement[]
  approvedOrders          PurchaseOrder[]  @relation("POApprover")
  requestedTransfers      StockTransfer[]  @relation("TransferRequester")
  approvedTransfers       StockTransfer[]  @relation("TransferApprover")
  dispatchedTransfers     StockTransfer[]  @relation("TransferDispatcher")
  receivedTransfers       StockTransfer[]  @relation("TransferReceiver")
  ocrScansAsScanner       OcrScan[]        @relation("OcrScanner")
  ocrScansAsConfirmer     OcrScan[]        @relation("OcrConfirmer")
  syncQueues              SyncQueue[]      @relation("SyncQueueCreator")
  reviewedUploads         SupplierPortalUpload[] @relation("PortalReviewer")
  priceChangeLogs         PriceChangeLog[]

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at") // soft delete

  @@unique([tenantId, email])
  @@map("users")
  @@index([tenantId])
  @@index([branchId])
  @@index([isActive])
  @@index([deletedAt])
}

/// Business branches/locations
model Branch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  name      String
  slug      String   @map("slug")
  address   String?
  phone     String?
  timezone  String   @default("UTC")
  isActive  Boolean  @default(true) @map("is_active")
  
  // Relations
  tenant                   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users                    User[]
  staffRegistrationTokens  StaffRegistrationToken[]
  integration              BranchIntegration?
  stockLevels              StockLevel[]
  stockMovements           StockMovement[]
  branchSuppliers          BranchSupplier[]
  purchaseOrders           PurchaseOrder[]
  transfersFrom            StockTransfer[]  @relation("TransferFrom")
  transfersTo              StockTransfer[]  @relation("TransferTo")
  whatsappMessageLogs      WhatsappMessageLog[]
  ocrScans                 OcrScan[]
  syncQueues               SyncQueue[]
  supplierPortal           BranchSupplierPortal?
  supplierPortalUploads    SupplierPortalUpload[]
  scheduledReports         ScheduledReport[]
  priceChangeLogs          PriceChangeLog[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete

  @@unique([tenantId, slug])
  @@map("branches")
  @@index([tenantId])
  @@index([isActive])
  @@index([deletedAt])
}

/// ERP/POS integration config per branch
model BranchIntegration {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @db.Uuid @map("tenant_id")
  branchId            String    @db.Uuid @map("branch_id")
  adapterType         String    @map("adapter_type")
  agentId             String?   @map("agent_id")
  agentVersion        String?   @map("agent_version")
  webserviceUrl       String?   @map("webservice_url")
  apiKeyEncrypted     String?   @map("api_key_encrypted")
  apiSecretEncrypted  String?   @map("api_secret_encrypted")
  pollingIntervalSec  Int       @default(10) @map("polling_interval_sec")
  connectionStatus    String    @default("PENDING_INSTALL") @map("connection_status")
  lastReadSyncAt      DateTime? @map("last_read_sync_at")
  lastWriteSyncAt     DateTime? @map("last_write_sync_at")
  errorMessage        String?   @map("error_message")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([branchId])
  @@map("branch_integrations")
  @@index([tenantId])
  @@index([connectionStatus])
}

/// Catalogue of supported ERP/POS adapter definitions
model IntegrationAdapter {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adapterType       String   @unique @map("adapter_type")
  displayName       String   @map("display_name")
  webserviceType    String   @map("webservice_type")
  readEndpoint      String   @map("read_endpoint")
  writeEndpoint     String   @map("write_endpoint")
  authType          String   @map("auth_type")
  fieldMappings     Json     @map("field_mappings")
  supportedVersions String?  @map("supported_versions")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("integration_adapters")
}

/// Staff registration tokens for inviting team members
model StaffRegistrationToken {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid @map("tenant_id")
  branchId      String   @db.Uuid @map("branch_id")
  token         String   @unique
  applicantName String   @map("applicant_name")
  applicantEmail String  @map("applicant_email")
  status        StaffTokenStatus @default(PENDING)
  createdUserId String?  @db.Uuid @map("created_user_id")
  approvedBy    String?  @db.Uuid @map("approved_by")
  approvedAt    DateTime? @map("approved_at")
  usedAt        DateTime? @map("used_at")
  cancelledBy   String?  @db.Uuid @map("cancelled_by")
  cancelledAt   DateTime? @map("cancelled_at")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("staff_registration_tokens")
  @@index([branchId, status])
  @@index([tenantId])
}

// ============================================
// PRODUCT CATALOGUE
// ============================================

/// Product categories — supports one level of nesting via self-relation
model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  parentId  String?  @db.Uuid @map("parent_id")
  name      String
  slug      String

  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@unique([tenantId, slug])
  @@map("categories")
  @@index([tenantId])
}

/// Tenant-level product catalogue
model Product {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid @map("tenant_id")
  categoryId String    @db.Uuid @map("category_id")
  sku        String
  barcode    String?
  name       String
  unit          String
  unitsPerCase  Int?      @map("units_per_case")
  variants      Json      @default("[]")
  imageUrl   String?   @map("image_url")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  category            Category            @relation(fields: [categoryId], references: [id])
  stockLevels         StockLevel[]
  stockMovements      StockMovement[]
  purchaseOrderItems  PurchaseOrderItem[]
  stockTransfers      StockTransfer[]
  priceChangeLogs     PriceChangeLog[]

  @@unique([tenantId, sku])
  @@map("products")
  @@index([tenantId])
  @@index([tenantId, barcode])
}

// ============================================
// STOCK
// ============================================

/// Current stock quantity per product per branch
model StockLevel {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid @map("tenant_id")
  productId         String    @db.Uuid @map("product_id")
  branchId          String    @db.Uuid @map("branch_id")
  quantity          Decimal   @default(0) @db.Decimal(12, 3)
  reservedQty       Decimal   @default(0) @map("reserved_qty") @db.Decimal(12, 3)
  minThreshold      Decimal   @map("min_threshold") @db.Decimal(12, 3)
  maxThreshold      Decimal?  @map("max_threshold") @db.Decimal(12, 3)
  maxThresholdSet   Boolean   @default(false) @map("max_threshold_set")
  maxThresholdSetAt DateTime? @map("max_threshold_set_at")
  thresholdSource   String    @default("AUTO") @map("threshold_source")
  version           Int       @default(0)
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
  @@map("stock_levels")
  @@index([tenantId])
  @@index([branchId, quantity])
}

/// Immutable log of every stock change
model StockMovement {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  productId     String    @db.Uuid @map("product_id")
  branchId      String    @db.Uuid @map("branch_id")
  movementType  String    @map("movement_type")
  quantity      Decimal   @db.Decimal(12, 3)
  referenceId   String?   @db.Uuid @map("reference_id")
  referenceType String?   @map("reference_type")
  notes         String?
  createdBy     String    @db.Uuid @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  user    User    @relation(fields: [createdBy], references: [id])

  @@map("stock_movements")
  @@index([branchId, createdAt(sort: Desc)])
  @@index([productId, branchId, createdAt(sort: Desc)])
}

// ============================================
// SUPPLIERS & PURCHASE ORDERS
// ============================================

/// Supplier/vendor master data
model Supplier {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid @map("tenant_id")
  name              String
  contactName       String?   @map("contact_name")
  whatsappNumber    String    @map("whatsapp_number")
  otpVerified       Boolean   @default(false) @map("otp_verified")
  otpVerifiedAt     DateTime? @map("otp_verified_at")
  productCategories Json      @default("[]") @map("product_categories")
  notes             String?
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  branchSuppliers     BranchSupplier[]
  purchaseOrders      PurchaseOrder[]
  whatsappMessageLogs WhatsappMessageLog[]
  portalUploads       SupplierPortalUpload[]

  @@map("suppliers")
  @@index([tenantId])
}

/// Junction: which branches work with which suppliers
model BranchSupplier {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String   @db.Uuid @map("branch_id")
  supplierId String   @db.Uuid @map("supplier_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  branch   Branch   @relation(fields: [branchId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([branchId, supplierId])
  @@map("branch_suppliers")
  @@index([branchId, isPrimary])
}

/// Purchase order header
model PurchaseOrder {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid @map("tenant_id")
  branchId   String    @db.Uuid @map("branch_id")
  supplierId String    @db.Uuid @map("supplier_id")
  status     String    @default("DRAFT")
  approvedBy String?   @db.Uuid @map("approved_by")
  approvedAt DateTime? @map("approved_at")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  branch              Branch               @relation(fields: [branchId], references: [id])
  supplier            Supplier             @relation(fields: [supplierId], references: [id])
  approver            User?                @relation("POApprover", fields: [approvedBy], references: [id])
  items               PurchaseOrderItem[]
  whatsappMessageLogs WhatsappMessageLog[]

  @@map("purchase_orders")
  @@index([tenantId])
  @@index([branchId, status])
}

/// Purchase order line items
model PurchaseOrderItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poId             String   @db.Uuid @map("po_id")
  productId        String   @db.Uuid @map("product_id")
  quantityOrdered  Decimal  @map("quantity_ordered") @db.Decimal(12, 3)
  quantityReceived Decimal  @default(0) @map("quantity_received") @db.Decimal(12, 3)
  unitPrice        Decimal? @map("unit_price") @db.Decimal(12, 2)
  notes            String?

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
  @@index([poId])
}

// ============================================
// STOCK TRANSFERS
// ============================================

/// Inter-branch stock transfer lifecycle: REQUESTED→APPROVED→IN_TRANSIT→DELIVERED
model StockTransfer {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid @map("tenant_id")
  fromBranchId String    @db.Uuid @map("from_branch_id")
  toBranchId   String    @db.Uuid @map("to_branch_id")
  productId    String    @db.Uuid @map("product_id")
  quantity     Decimal   @db.Decimal(12, 3)
  status       String    @default("REQUESTED")
  requestedBy  String    @db.Uuid @map("requested_by")
  approvedBy   String?   @db.Uuid @map("approved_by")
  approvedAt   DateTime? @map("approved_at")
  dispatchedBy String?   @db.Uuid @map("dispatched_by")
  dispatchedAt DateTime? @map("dispatched_at")
  receivedBy   String?   @db.Uuid @map("received_by")
  receivedAt   DateTime? @map("received_at")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  fromBranch Branch   @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch   @relation("TransferTo", fields: [toBranchId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
  requester  User     @relation("TransferRequester", fields: [requestedBy], references: [id])
  approver   User?    @relation("TransferApprover", fields: [approvedBy], references: [id])
  dispatcher User?    @relation("TransferDispatcher", fields: [dispatchedBy], references: [id])
  receiver   User?    @relation("TransferReceiver", fields: [receivedBy], references: [id])

  @@map("stock_transfers")
  @@index([tenantId])
  @@index([fromBranchId, status])
  @@index([toBranchId, status])
}

// ============================================
// WHATSAPP NOTIFICATIONS
// ============================================

model WhatsappMessageLog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid @map("tenant_id")
  branchId       String    @db.Uuid @map("branch_id")
  supplierId     String    @db.Uuid @map("supplier_id")
  poId           String    @db.Uuid @map("po_id")
  messageBody    String    @map("message_body")
  whatsappNumber String    @map("whatsapp_number")
  status         String    @default("PENDING")
  sentAt         DateTime? @map("sent_at")
  errorMessage   String?   @map("error_message")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  branch   Branch        @relation(fields: [branchId], references: [id])
  supplier Supplier      @relation(fields: [supplierId], references: [id])
  order    PurchaseOrder @relation(fields: [poId], references: [id])

  @@map("whatsapp_message_logs")
  @@index([tenantId])
  @@index([poId, status])
}

// ============================================
// OCR SCANS
// ============================================

model OcrScan {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid @map("tenant_id")
  branchId     String    @db.Uuid @map("branch_id")
  scannedBy    String    @db.Uuid @map("scanned_by")
  imageUrl     String    @map("image_url")
  rawOcrResult Json?     @map("raw_ocr_result")
  parsedLines  Json?     @map("parsed_lines")
  status       String    @default("PENDING")
  confirmedBy  String?   @db.Uuid @map("confirmed_by")
  confirmedAt  DateTime? @map("confirmed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  branch    Branch @relation(fields: [branchId], references: [id])
  scanner   User   @relation("OcrScanner", fields: [scannedBy], references: [id])
  confirmer User?  @relation("OcrConfirmer", fields: [confirmedBy], references: [id])

  @@map("ocr_scans")
  @@index([tenantId])
  @@index([branchId, status])
}

// ============================================
// REVERSE SYNC QUEUE
// ============================================

model SyncQueue {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  branchId      String    @db.Uuid @map("branch_id")
  direction     String    @default("OUTBOUND")
  operationType String    @map("operation_type")
  payload       Json
  adapterType   String    @map("adapter_type")
  status        String    @default("PENDING")
  attemptCount  Int       @default(0) @map("attempt_count")
  lastAttemptAt DateTime? @map("last_attempt_at")
  errorMessage  String?   @map("error_message")
  createdBy     String?   @db.Uuid @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")

  tenant  Tenant    @relation(fields: [tenantId], references: [id])
  branch  Branch    @relation(fields: [branchId], references: [id])
  creator User?     @relation("SyncQueueCreator", fields: [createdBy], references: [id])
  logs    SyncLog[]

  @@map("sync_queue")
  @@index([tenantId])
  @@index([branchId, status])
}

model SyncLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid @map("tenant_id")
  queueId         String   @db.Uuid @map("queue_id")
  attemptNumber   Int      @map("attempt_number")
  direction       String
  requestPayload  String?  @map("request_payload")
  responsePayload String?  @map("response_payload")
  status          String
  errorDetail     String?  @map("error_detail")
  executedAt      DateTime @default(now()) @map("executed_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  syncQueue SyncQueue @relation(fields: [queueId], references: [id])

  @@map("sync_logs")
  @@index([tenantId])
  @@index([queueId])
}

// ============================================
// SUPPLIER PORTAL
// ============================================

model BranchSupplierPortal {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  branchId  String   @db.Uuid @map("branch_id")
  subdomain String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant                 @relation(fields: [tenantId], references: [id])
  branch  Branch                 @relation(fields: [branchId], references: [id])
  uploads SupplierPortalUpload[]

  @@unique([branchId])
  @@map("branch_supplier_portals")
  @@index([subdomain])
}

model SupplierPortalUpload {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid @map("tenant_id")
  branchId          String    @db.Uuid @map("branch_id")
  supplierId        String?   @db.Uuid @map("supplier_id")
  portalId          String    @db.Uuid @map("portal_id")
  uploaderPhone     String    @map("uploader_phone")
  otpVerifiedAt     DateTime  @map("otp_verified_at")
  pdfUrl            String    @map("pdf_url")
  ocrExtractedFirm  String?   @map("ocr_extracted_firm")
  ocrExtractedPhone String?   @map("ocr_extracted_phone")
  effectivePhone    String    @map("effective_phone")
  ocrStatus         String    @default("PENDING") @map("ocr_status")
  uploadType        String    @map("upload_type")
  status            String    @default("PENDING_REVIEW") @map("status")
  reviewedBy        String?   @db.Uuid @map("reviewed_by")
  reviewedAt        DateTime? @map("reviewed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  tenant   Tenant               @relation(fields: [tenantId], references: [id])
  branch   Branch               @relation(fields: [branchId], references: [id])
  portal   BranchSupplierPortal @relation(fields: [portalId], references: [id])
  supplier Supplier?            @relation(fields: [supplierId], references: [id])
  reviewer User?                @relation("PortalReviewer", fields: [reviewedBy], references: [id])

  @@map("supplier_portal_uploads")
  @@index([tenantId])
  @@index([branchId, status])
}

// ============================================
// REPORTING
// ============================================

model ScheduledReport {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid @map("tenant_id")
  branchId    String?   @db.Uuid @map("branch_id")
  reportType  String    @map("report_type")
  reportDate  DateTime  @map("report_date") @db.Date
  generatedAt DateTime  @default(now()) @map("generated_at")
  payload     Json
  pdfUrl      String?   @map("pdf_url")
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([tenantId, reportType, reportDate])
  @@map("scheduled_reports")
  @@index([tenantId, isRead])
}

model PriceChangeLog {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @db.Uuid @map("tenant_id")
  productId           String   @db.Uuid @map("product_id")
  branchId            String?  @db.Uuid @map("branch_id")
  oldPrice            Decimal  @map("old_price") @db.Decimal(12,2)
  newPrice            Decimal  @map("new_price") @db.Decimal(12,2)
  changePct           Decimal  @map("change_pct") @db.Decimal(5,2)
  categoryAvgIncrease Decimal? @map("category_avg_increase") @db.Decimal(5,2)
  anomalyFlag         Boolean  @default(false) @map("anomaly_flag")
  anomalyRatio        Decimal? @map("anomaly_ratio") @db.Decimal(5,2)
  changedBy           String   @db.Uuid @map("changed_by")
  createdAt           DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  product Product  @relation(fields: [productId], references: [id])
  branch  Branch?  @relation(fields: [branchId], references: [id])
  changer User     @relation(fields: [changedBy], references: [id])

  @@map("price_change_logs")
  @@index([tenantId])
  @@index([tenantId, anomalyFlag])
}
