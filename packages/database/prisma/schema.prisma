// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  SUPER_ADMIN
  PATRON
  SUBE_MUDURU
  KASIYER
  DEPO
}

enum StaffTokenStatus {
  PENDING
  APPROVED
  USED
  CANCELLED
}

// ============================================
// CORE TABLES
// ============================================

/// Multi-tenant root entity
model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId    TenantPlan @default(STARTER) @map("plan_id")
  companyName String @map("company_name")
  taxNumber String @unique @map("tax_number")
  status    TenantStatus @default(ACTIVE)
  settings  Json? // flexible config storage
  
  // Relations
  users                    User[]
  branches                 Branch[]
  staffRegistrationTokens  StaffRegistrationToken[]
  branchIntegrations       BranchIntegration[]
  categories               Category[]
  products                 Product[]
  stockLevels              StockLevel[]
  stockMovements           StockMovement[]
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete

  @@map("tenants")
  @@index([status])
  @@index([deletedAt])
}

/// User accounts - multi-tenant
model User {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid @map("tenant_id")
  branchId        String?  @db.Uuid @map("branch_id")
  email           String   @map("email")
  passwordHash    String   @map("password_hash")
  role            UserRole?
  isActive        Boolean  @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  
  // Relations
  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  stockMovements  StockMovement[]
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at") // soft delete

  @@unique([tenantId, email])
  @@map("users")
  @@index([tenantId])
  @@index([branchId])
  @@index([isActive])
  @@index([deletedAt])
}

/// Business branches/locations
model Branch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  name      String
  slug      String   @map("slug")
  address   String?
  phone     String?
  timezone  String   @default("UTC")
  isActive  Boolean  @default(true) @map("is_active")
  
  // Relations
  tenant                   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users                    User[]
  staffRegistrationTokens  StaffRegistrationToken[]
  integration              BranchIntegration?
  stockLevels              StockLevel[]
  stockMovements           StockMovement[]
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete

  @@unique([tenantId, slug])
  @@map("branches")
  @@index([tenantId])
  @@index([isActive])
  @@index([deletedAt])
}

/// ERP/POS integration config per branch
model BranchIntegration {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @db.Uuid @map("tenant_id")
  branchId            String    @db.Uuid @map("branch_id")
  adapterType         String    @map("adapter_type")
  agentId             String?   @map("agent_id")
  agentVersion        String?   @map("agent_version")
  webserviceUrl       String?   @map("webservice_url")
  apiKeyEncrypted     String?   @map("api_key_encrypted")
  apiSecretEncrypted  String?   @map("api_secret_encrypted")
  pollingIntervalSec  Int       @default(10) @map("polling_interval_sec")
  connectionStatus    String    @default("PENDING_INSTALL") @map("connection_status")
  lastReadSyncAt      DateTime? @map("last_read_sync_at")
  lastWriteSyncAt     DateTime? @map("last_write_sync_at")
  errorMessage        String?   @map("error_message")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([branchId])
  @@map("branch_integrations")
  @@index([tenantId])
  @@index([connectionStatus])
}

/// Catalogue of supported ERP/POS adapter definitions
model IntegrationAdapter {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adapterType       String   @unique @map("adapter_type")
  displayName       String   @map("display_name")
  webserviceType    String   @map("webservice_type")
  readEndpoint      String   @map("read_endpoint")
  writeEndpoint     String   @map("write_endpoint")
  authType          String   @map("auth_type")
  fieldMappings     Json     @map("field_mappings")
  supportedVersions String?  @map("supported_versions")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("integration_adapters")
}

/// Staff registration tokens for inviting team members
model StaffRegistrationToken {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid @map("tenant_id")
  branchId      String   @db.Uuid @map("branch_id")
  token         String   @unique
  applicantName String   @map("applicant_name")
  applicantEmail String  @map("applicant_email")
  status        StaffTokenStatus @default(PENDING)
  createdUserId String?  @db.Uuid @map("created_user_id")
  approvedBy    String?  @db.Uuid @map("approved_by")
  approvedAt    DateTime? @map("approved_at")
  usedAt        DateTime? @map("used_at")
  cancelledBy   String?  @db.Uuid @map("cancelled_by")
  cancelledAt   DateTime? @map("cancelled_at")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("staff_registration_tokens")
  @@index([branchId, status])
  @@index([tenantId])
}

// ============================================
// PRODUCT CATALOGUE
// ============================================

/// Product categories — supports one level of nesting via self-relation
model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  parentId  String?  @db.Uuid @map("parent_id")
  name      String
  slug      String

  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@unique([tenantId, slug])
  @@map("categories")
  @@index([tenantId])
}

/// Tenant-level product catalogue
model Product {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid @map("tenant_id")
  categoryId String    @db.Uuid @map("category_id")
  sku        String
  barcode    String?
  name       String
  unit       String
  variants   Json      @default("[]")
  imageUrl   String?   @map("image_url")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  category       Category        @relation(fields: [categoryId], references: [id])
  stockLevels    StockLevel[]
  stockMovements StockMovement[]

  @@unique([tenantId, sku])
  @@map("products")
  @@index([tenantId])
  @@index([tenantId, barcode])
}

// ============================================
// STOCK
// ============================================

/// Current stock quantity per product per branch
model StockLevel {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid @map("tenant_id")
  productId         String    @db.Uuid @map("product_id")
  branchId          String    @db.Uuid @map("branch_id")
  quantity          Decimal   @default(0) @db.Decimal(12, 3)
  reservedQty       Decimal   @default(0) @map("reserved_qty") @db.Decimal(12, 3)
  minThreshold      Decimal   @map("min_threshold") @db.Decimal(12, 3)
  maxThreshold      Decimal?  @map("max_threshold") @db.Decimal(12, 3)
  maxThresholdSet   Boolean   @default(false) @map("max_threshold_set")
  maxThresholdSetAt DateTime? @map("max_threshold_set_at")
  thresholdSource   String    @default("AUTO") @map("threshold_source")
  version           Int       @default(0)
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
  @@map("stock_levels")
  @@index([tenantId])
  @@index([branchId, quantity])
}

/// Immutable log of every stock change
model StockMovement {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  productId     String    @db.Uuid @map("product_id")
  branchId      String    @db.Uuid @map("branch_id")
  movementType  String    @map("movement_type")
  quantity      Decimal   @db.Decimal(12, 3)
  referenceId   String?   @db.Uuid @map("reference_id")
  referenceType String?   @map("reference_type")
  notes         String?
  createdBy     String    @db.Uuid @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  user    User    @relation(fields: [createdBy], references: [id])

  @@map("stock_movements")
  @@index([branchId, createdAt(sort: Desc)])
  @@index([productId, branchId, createdAt(sort: Desc)])
}
